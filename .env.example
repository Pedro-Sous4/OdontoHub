# Example environment variables. Copy to .env for local overrides (not committed).

# Backend (API Gateway + microservices)
API_GATEWAY_PORT=3000
JWT_SECRET=change_me
DATABASE_URL=postgres://postgres:postgres@postgres:5432/odontohub
REDIS_URL=redis://redis:6379

# Para desenvolvimento via Docker compose
BYPASS_AUTH=true
BYPASS_TENANT_ID=00000000-0000-0000-0000-000000000000
USE_CONTAINER_HOSTS=true

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:3000
